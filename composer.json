{
    "name": "suioip/newsletter-suioip",
    "type": "project",
    "description": "Smart Mailer Pro Open Source — plateforme d'envoi de newsletters, architecture modulaire DDD/hexagonale sur Laravel.",
    "keywords": ["laravel", "newsletter", "mailer", "ddd", "hexagonal"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "nwidart/laravel-modules": "^11.0",
        "directorytree/ldaprecord-laravel": "^3.3",
        "subfission/cas": "^5.0",
        "darkaonline/l5-swagger": "^8.6",
        "spatie/laravel-permission": "^6.9",
        "spatie/laravel-data": "^4.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.17",
        "laravel/sail": "^1.30",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.3",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan modules:list"
        ],
        "test": "pest",
        "test:coverage": "pest --coverage --min=80",
        "lint": "pint",
        "lint:test": "pint --test"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
